{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "emitDeclarationOnly": false,
    "lib": ["ES2022", "DOM"],
    "module": "Preserve",
    "noEmit": true,
    "rootDir": "./src",
