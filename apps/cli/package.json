{
  "name": "@k-msg/cli",
  "version": "0.9.10",
  "private": false,
  "description": "k-msg CLI (prebuilt binaries via GitHub Releases)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "k-msg": "./bin/k-msg.js",
    "kmsg": "./bin/k-msg.js"
  },
  "files": [
    "bin",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "generate": "bun run scripts/generate-runtime.ts",
    "doctor:completions": "bun run generate && bun run scripts/doctor-completions.ts --strict",
    "build": "bun run scripts/build-runtime.ts",
    "build:all": "bun run scripts/build-runtime.ts --targets all",
    "build:native": "bun run scripts/build-runtime.ts --targets native",
    "build:js": "bun run generate && bun build src/k-msg.ts --outdir=dist --format=esm --target=bun",
    "dev": "bun run generate && bun --watch src/k-msg.ts",
    "typecheck": "bun run generate && ttsc --noEmit -p tsconfig.json",
    "test": "bun run generate && bun test",
    "schema:generate": "bun run scripts/generate-config-schema.ts",
    "schema:check": "bun run scripts/generate-config-schema.ts --check",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@gunshi/plugin-completion": "0.35.1",
    "@k-msg/channel": "workspace:*",
    "@k-msg/core": "workspace:*",
    "@k-msg/messaging": "workspace:*",
    "@k-msg/provider": "workspace:*",
    "@k-msg/template": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "gunshi": "0.35.1",
    "k-msg": "workspace:*",
    "solapi": "^6.0.1",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "keywords": [
    "alimtalk",
    "cli",
    "messaging",
    "kakao"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/k-otp/k-msg"
  },
  "license": "MIT"
}
