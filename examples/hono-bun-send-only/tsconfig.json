{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun", "node"],
    "plugins": [{ "transform": "@ttsc/lint" }],
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
